@page
@model STASIS.Pages.LabSetup.VisitTypesModel
@{
    ViewData["Title"] = "Manage Visit Types";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h5 class="mt-3">Add Visit Type</h5>
<form method="post" asp-page-handler="Add" class="row g-2 mb-4">
    <div class="col-md-4">
        <input asp-for="Input.VisitTypeName" class="form-control" placeholder="Visit type name *" />
        <span asp-validation-for="Input.VisitTypeName" class="text-danger small"></span>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Add</button>
    </div>
</form>

<h5>Existing Visit Types</h5>
@if (!Model.VisitTypes.Any())
{
    <p class="text-muted">No visit types defined yet.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th style="width:180px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var vt in Model.VisitTypes)
            {
                <tr>
                    <td>@vt.VisitTypeName</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@vt.VisitTypeID"
                                data-name="@vt.VisitTypeName">
                            Edit
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@vt.VisitTypeID"
                              style="display:inline"
                              onsubmit="return confirm('Delete visit type ' + this.dataset.name + '?');" data-name="@vt.VisitTypeName">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Visit Type</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.VisitTypeID" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input asp-for="Input.VisitTypeName" id="editName" class="form-control" />
                        <span asp-validation-for="Input.VisitTypeName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editName').value = btn.dataset.name || '';
        });
    </script>
}
