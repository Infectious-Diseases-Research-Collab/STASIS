@page
@model STASIS.Pages.LabSetup.RacksModel
@{
    ViewData["Title"] = "Manage Racks";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h5 class="mt-3">Add Rack</h5>
<form method="post" asp-page-handler="Add" class="row g-2 mb-4">
    <div class="col-md-3">
        <input asp-for="Input.RackName" class="form-control" placeholder="Rack name *" />
        <span asp-validation-for="Input.RackName" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <select id="addFreezerSelect" class="form-select">
            <option value="">— Select freezer —</option>
            @foreach (var item in Model.FreezerOptions)
            {
                <option value="@item.Value">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select asp-for="Input.CompartmentID" id="addCompartmentSelect" class="form-select">
            <option value="">— Select compartment —</option>
        </select>
    </div>
    <div class="col-md-2">
        <input asp-for="Input.Description" class="form-control" placeholder="Description" />
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">Add</button>
    </div>
</form>

<h5>Existing Racks</h5>
@if (!Model.Racks.Any())
{
    <p class="text-muted">No racks defined yet.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Freezer</th>
                <th>Compartment</th>
                <th>Description</th>
                <th>Boxes</th>
                <th style="width:180px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model.Racks)
            {
                <tr>
                    <td>@r.RackName</td>
                    <td>@(r.Compartment?.Freezer?.FreezerName ?? "-")</td>
                    <td>@(r.Compartment?.CompartmentName ?? "-")</td>
                    <td>@(r.Description ?? "-")</td>
                    <td>@r.Boxes.Count</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@r.RackID"
                                data-name="@r.RackName"
                                data-description="@r.Description"
                                data-compartmentid="@r.CompartmentID"
                                data-freezerid="@r.Compartment?.FreezerID">
                            Edit
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@r.RackID"
                              style="display:inline"
                              onsubmit="return confirm('Delete rack @r.RackName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Rack</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.RackID" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input asp-for="Input.RackName" id="editName" class="form-control" />
                        <span asp-validation-for="Input.RackName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Freezer</label>
                        <select id="editFreezerSelect" class="form-select">
                            <option value="">— Select freezer —</option>
                            @foreach (var item in Model.FreezerOptions)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Compartment</label>
                        <select asp-for="Input.CompartmentID" id="editCompartmentSelect" class="form-select">
                            <option value="">— Select compartment —</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input asp-for="Input.Description" id="editDescription" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        async function loadCompartments(freezerId, selectEl, preselect) {
            selectEl.innerHTML = '<option value="">Loading...</option>';
            if (!freezerId) {
                selectEl.innerHTML = '<option value="">— Select freezer first —</option>';
                return;
            }
            var resp = await fetch('?handler=Compartments&freezerId=' + freezerId);
            var compartments = await resp.json();
            selectEl.innerHTML = '<option value="">— Select —</option>';
            compartments.forEach(function (c) {
                var opt = document.createElement('option');
                opt.value = c.compartmentID;
                opt.textContent = c.compartmentName;
                if (preselect && c.compartmentID == preselect) opt.selected = true;
                selectEl.appendChild(opt);
            });
        }

        // Add form cascading
        var addFreezerSelect = document.getElementById('addFreezerSelect');
        var addCompartmentSelect = document.getElementById('addCompartmentSelect');
        addFreezerSelect.addEventListener('change', function () {
            loadCompartments(this.value, addCompartmentSelect);
        });

        // Edit modal
        var editFreezerSelect = document.getElementById('editFreezerSelect');
        var editCompartmentSelect = document.getElementById('editCompartmentSelect');
        editFreezerSelect.addEventListener('change', function () {
            loadCompartments(this.value, editCompartmentSelect);
        });

        document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editName').value = btn.dataset.name;
            document.getElementById('editDescription').value = btn.dataset.description || '';
            editFreezerSelect.value = btn.dataset.freezerid || '';
            if (btn.dataset.freezerid) {
                loadCompartments(btn.dataset.freezerid, editCompartmentSelect, btn.dataset.compartmentid);
            } else {
                editCompartmentSelect.innerHTML = '<option value="">— Select freezer first —</option>';
            }
        });
    </script>
}
