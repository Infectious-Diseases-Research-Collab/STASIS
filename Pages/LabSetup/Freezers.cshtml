@page
@model STASIS.Pages.LabSetup.FreezersModel
@{
    ViewData["Title"] = "Manage Freezers";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h5 class="mt-3">Add Freezer</h5>
<form method="post" asp-page-handler="Add" class="row g-2 mb-4">
    <div class="col-md-4">
        <input asp-for="Input.FreezerName" class="form-control" placeholder="Freezer name *" />
        <span asp-validation-for="Input.FreezerName" class="text-danger small"></span>
    </div>
    <div class="col-md-2">
        <input asp-for="Input.Temperature" class="form-control" placeholder="Temp (°C)" type="number" />
    </div>
    <div class="col-md-4">
        <input asp-for="Input.LocationInBuilding" class="form-control" placeholder="Location in building" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Add</button>
    </div>
</form>

<h5>Existing Freezers</h5>
@if (!Model.Freezers.Any())
{
    <p class="text-muted">No freezers defined yet.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Name</th>
                <th>Temp (°C)</th>
                <th>Location</th>
                <th>Racks</th>
                <th style="width:180px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var f in Model.Freezers)
            {
                <tr>
                    <td>@f.FreezerName</td>
                    <td>@(f.Temperature?.ToString() ?? "-")</td>
                    <td>@(f.LocationInBuilding ?? "-")</td>
                    <td>@f.Racks.Count</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@f.FreezerID"
                                data-name="@f.FreezerName"
                                data-temp="@f.Temperature"
                                data-location="@f.LocationInBuilding">
                            Edit
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@f.FreezerID"
                              style="display:inline"
                              onsubmit="return confirm('Delete freezer @f.FreezerName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Freezer</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.FreezerID" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input asp-for="Input.FreezerName" id="editName" class="form-control" />
                        <span asp-validation-for="Input.FreezerName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Temperature (°C)</label>
                        <input asp-for="Input.Temperature" id="editTemp" class="form-control" type="number" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location in building</label>
                        <input asp-for="Input.LocationInBuilding" id="editLocation" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editName').value = btn.dataset.name;
            document.getElementById('editTemp').value = btn.dataset.temp || '';
            document.getElementById('editLocation').value = btn.dataset.location || '';
        });
    </script>
}
