@page
@model STASIS.Pages.LabSetup.CompartmentsModel
@{
    ViewData["Title"] = "Manage Compartments";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
}

<h5 class="mt-3">Add Compartment</h5>
<form method="post" asp-page-handler="Add" class="row g-2 mb-4">
    <div class="col-md-3">
        <select asp-for="Input.FreezerID" asp-items="Model.FreezerOptions" class="form-select">
            <option value="">— Select freezer * —</option>
        </select>
        <span asp-validation-for="Input.FreezerID" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <input asp-for="Input.CompartmentName" class="form-control" placeholder="Compartment name *" />
        <span asp-validation-for="Input.CompartmentName" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <input asp-for="Input.Description" class="form-control" placeholder="Description" />
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Add</button>
    </div>
</form>

<h5>Existing Compartments</h5>
@if (!Model.Compartments.Any())
{
    <p class="text-muted">No compartments defined yet.</p>
}
else
{
    <table class="table table-bordered table-sm">
        <thead class="table-light">
            <tr>
                <th>Freezer</th>
                <th>Name</th>
                <th>Description</th>
                <th>Racks</th>
                <th style="width:180px"></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var c in Model.Compartments)
            {
                <tr>
                    <td>@(c.Freezer?.FreezerName ?? "-")</td>
                    <td>@c.CompartmentName</td>
                    <td>@(c.Description ?? "-")</td>
                    <td>@c.Racks.Count</td>
                    <td>
                        <button class="btn btn-sm btn-outline-secondary"
                                data-bs-toggle="modal"
                                data-bs-target="#editModal"
                                data-id="@c.CompartmentID"
                                data-name="@c.CompartmentName"
                                data-description="@c.Description"
                                data-freezerid="@c.FreezerID">
                            Edit
                        </button>
                        <form method="post" asp-page-handler="Delete" asp-route-id="@c.CompartmentID"
                              style="display:inline"
                              onsubmit="return confirm('Delete compartment @c.CompartmentName?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<!-- Edit Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog">
        <form method="post" asp-page-handler="Edit">
            @Html.AntiForgeryToken()
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Compartment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="Input.CompartmentID" id="editId" />
                    <div class="mb-3">
                        <label class="form-label">Freezer *</label>
                        <select asp-for="Input.FreezerID" id="editFreezerId"
                                asp-items="Model.FreezerOptions" class="form-select">
                            <option value="">— Select freezer —</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Name *</label>
                        <input asp-for="Input.CompartmentName" id="editName" class="form-control" />
                        <span asp-validation-for="Input.CompartmentName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input asp-for="Input.Description" id="editDescription" class="form-control" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('editModal').addEventListener('show.bs.modal', function (e) {
            var btn = e.relatedTarget;
            document.getElementById('editId').value = btn.dataset.id;
            document.getElementById('editName').value = btn.dataset.name;
            document.getElementById('editDescription').value = btn.dataset.description || '';
            document.getElementById('editFreezerId').value = btn.dataset.freezerid || '';
        });
    </script>
}
